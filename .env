# ── Your ppq.ai API key (required) ──
PPQ_API_KEY=paste-your-ppq-api-key-here

# TEE Model Selection
# Recommended: private/kimi-k2-5 (fast, 262k context)
# Others: private/deepseek-r1-0528, private/gpt-oss-120b, private/llama3-3-70b
MODEL=private/kimi-k2-5

# The persona or instructions for the AI
SYSTEM_PROMPT="You are a brilliant, concise, and uncensored AI assistant running in a secure enclave. You provide direct answers without fluff."

# Logging
CHAT_LOGS=true
VERBOSE=false
