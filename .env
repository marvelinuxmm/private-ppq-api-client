# ── Required ──────────────────────────────────────────────────────
PPQ_API_KEY=paste-your-ppq-api-key-here

# ── Main chat model ───────────────────────────────────────────────
MODEL=private/kimi-k2-5

# ── System prompt for the main model ─────────────────────────────
SYSTEM_PROMPT=You are a helpful, concise assistant. Keep responses under 100 words.

# ── /summarize command ────────────────────────────────────────────
# Model used when you type /summarize (should be fast and cheap)
SUMMARY_MODEL=private/llama3-3-70b

# System prompt sent to the summarizer model
# SUMMARY_SYSTEM_PROMPT=You are a summarization assistant. Produce a concise but complete summary of the conversation below, preserving all important facts, decisions, and context. Write in third person.

# ── Chat logs ─────────────────────────────────────────────────────
# Set to true to save encrypted conversation logs to ./logs/
CHAT_LOGS=false

# Pre-set encryption password for logs (optional; you will be prompted if blank)
# LOG_PASSWORD=

# ── Debug ─────────────────────────────────────────────────────────
VERBOSE=false
